<div class="toast" id="toast"></div>

<script>
const REPO = 'souravbhuiyan12245-hue/sstopup';
const API_READ = `https://raw.githubusercontent.com/${REPO}/main/prices.json`;
const GH_API = `https://api.github.com/repos/${REPO}/contents/prices.json`;
const TG_BOT = '8709358566:AAFAIJGxh5YwQxB7dI0DxVMGNhiLfxY37-g';
const TG_CHAT = '8687506733';
const TG_API = `https://api.telegram.org/bot${TG_BOT}/sendMessage`;
const WA_NUMBER = '8801606335174';

// Embedded default prices (fallback)
const DEFAULT_PRICES = {"diamonds":{"25":{"price":35,"original":40},"50":{"price":65,"original":75},"100":{"price":120,"original":140},"310":{"price":350,"original":400},"520":{"price":580,"original":650},"1060":{"price":1100,"original":1250},"2180":{"price":2200,"original":2500},"5600":{"price":5500,"original":6200},"10120":{"price":10000,"original":11500}},"passes":{"weekly_lite":{"price":120,"original":140,"name":"Weekly Lite"},"weekly_1x":{"price":250,"original":290,"name":"1X Weekly"},"weekly_2x":{"price":480,"original":550,"name":"2X Weekly"},"monthly":{"price":950,"original":1100,"name":"Monthly"}},"specials":{"evo_access":{"price":850,"original":1000,"name":"EVO Access"},"level_up":{"price":450,"original":550,"name":"Level Up Pass"}},"announcement":"","updated":"2026-02-24"};

let prices = DEFAULT_PRICES;
let selectedDiamond = null;
let selectedPayment = 'bkash';
let currentType = 'diamond';

// Load prices
async function loadPrices() {
    // Use default prices immediately
    updateUI();
    // Then try to fetch latest from GitHub
    try {
        const r = await fetch(API_READ + '?t=' + Date.now(), { cache: 'no-store' });
        if (r.ok) {
            prices = await r.json();
            updateUI();
        }
    } catch(e) {
        console.log('Using default prices');
    }
}

function updateUI() {
    if (!prices) return;
    
    // Update offer cards
    if (prices.passes) {
        const p = prices.passes;
        if (p.weekly_lite) document.getElementById('offerWeeklyLite').textContent = '৳' + p.weekly_lite.price;
        if (p.weekly_1x) document.getElementById('offerWeekly1x').textContent = '৳' + p.weekly_1x.price;
        if (p.weekly_2x) document.getElementById('offerWeekly2x').textContent = '৳' + p.weekly_2x.price;
        if (p.monthly) document.getElementById('offerMonthly').textContent = '৳' + p.monthly.price;
    }
    
    // Announcement
    if (prices.announcement) {
        document.getElementById('announceText').textContent = prices.announcement;
        document.getElementById('announceBar').classList.add('show');
    }
}

async function openModal(type) {
    currentType = type;
    const modal = document.getElementById('modalOverlay');
    const diamondGroup = document.getElementById('diamondSelectGroup');
    const passGroup = document.getElementById('passInfoGroup');
    
    // Hide all select groups first
    diamondGroup.style.display = 'none';
    passGroup.style.display = 'none';
    document.getElementById('wmSelectGroup').style.display = 'none';
    
    if (type === 'diamond') {
        document.getElementById('modalTitle').textContent = '💎 Diamond TopUp';
        document.getElementById('modalSub').textContent = 'Enter your UID and select diamonds';
        diamondGroup.style.display = 'block';
        renderDiamonds();
    } else if (type === 'weekly_monthly') {
        document.getElementById('modalTitle').textContent = '📅 Weekly / Monthly';
        document.getElementById('modalSub').textContent = 'Select a package and enter your UID';
        document.getElementById('wmSelectGroup').style.display = 'block';
        renderWeeklyMonthly();
    } else {
        let name = type, price = 0;
        if (prices && prices.passes && prices.passes[type]) {
            name = prices.passes[type].name;
            price = prices.passes[type].price;
        } else if (prices && prices.specials && prices.specials[type]) {
            name = prices.specials[type].name;
            price = prices.specials[type].price;
        }
        document.getElementById('modalTitle').textContent = '📅 ' + name;
        document.getElementById('modalSub').textContent = 'Enter your UID and make payment';
        passGroup.style.display = 'block';
        document.getElementById('passName').textContent = name;
        document.getElementById('passPrice').textContent = '৳' + price;
        document.getElementById('totalAmount').textContent = '৳' + price;
        document.getElementById('payAmount').textContent = '৳' + price;
    }
    
    modal.classList.add('show');
}

function closeModal() {
    document.getElementById('modalOverlay').classList.remove('show');
    selectedDiamond = null;
}

function renderDiamonds() {
    if (!prices || !prices.diamonds) return;
    const grid = document.getElementById('diamondGrid');
    grid.innerHTML = '';
    const keys = Object.keys(prices.diamonds).sort((a,b) => Number(a) - Number(b));
    keys.forEach(k => {
        const d = prices.diamonds[k];
        grid.innerHTML += `
            <div class="diamond-option" onclick="selectDiamond(this,'${k}')">
                <span class="dm-icon">💎</span>
                ${k}
                <div class="dm-price">৳${d.price}</div>
                <div class="dm-original">৳${d.original}</div>
            </div>`;
    });
}

let selectedWM = null;

function renderWeeklyMonthly() {
    if (!prices || !prices.passes) return;
    const grid = document.getElementById('wmGrid');
    grid.innerHTML = '';
    const items = [
        { key: 'weekly_1x', icon: '👑' },
        { key: 'weekly_2x', icon: '⚡' },
        { key: 'monthly', icon: '🏆' }
    ];
    items.forEach(item => {
        const p = prices.passes[item.key];
        if (!p) return;
        grid.innerHTML += `
            <div class="diamond-option" onclick="selectWM(this,'${item.key}')">
                <span class="dm-icon">${item.icon}</span>
                ${p.name}
                <div class="dm-price">৳${p.price}</div>
                <div class="dm-original">৳${p.original}</div>
            </div>`;
    });
    selectedWM = null;
}

function selectWM(el, key) {
    document.querySelectorAll('#wmGrid .diamond-option').forEach(d => d.classList.remove('selected'));
    el.classList.add('selected');
    selectedWM = key;
    const price = prices.passes[key].price;
    document.getElementById('totalAmount').textContent = '৳' + price;
    document.getElementById('payAmount').textContent = '৳' + price;
}

function selectDiamond(el, key) {
    document.querySelectorAll('#diamondGrid .diamond-option').forEach(d => d.classList.remove('selected'));
    el.classList.add('selected');
    selectedDiamond = key;
    const price = prices.diamonds[key].price;
    document.getElementById('totalAmount').textContent = '৳' + price;
    document.getElementById('payAmount').textContent = '৳' + price;
}

function selectPayment(el, method) {
    document.querySelectorAll('#modalOverlay .payment-option').forEach(p => p.classList.remove('selected'));
    el.classList.add('selected');
    selectedPayment = method;
    
    const instrBox = document.getElementById('paymentInstructions');
    const numEl = document.getElementById('payNumber');
    const stepsEl = document.getElementById('paySteps');
    if (method === 'bkash') {
        instrBox.style.background = '#E2136E';
        numEl.textContent = '01606335174';
        stepsEl.innerHTML = `
            <div>📱 Dial <b>*247#</b> অথবা bKash App ওপেন করুন</div>
            <div>👉 <span style="background:#FFD700;color:#000;padding:1px 6px;border-radius:4px;font-weight:700;">Send Money</span> তে ক্লিক করুন</div>
            <div>📞 নম্বর: <b id="payNumber">01606335174</b> <button onclick="copyNumber()" style="background:rgba(255,255,255,0.25);border:none;color:#fff;padding:3px 10px;border-radius:6px;font-size:0.7rem;font-weight:700;cursor:pointer;margin-left:6px;">Copy</button></div>
            <div>💰 Amount: <span style="color:#FFD700;font-weight:800;" id="payAmount">${document.getElementById('totalAmount').textContent}</span></div>
            <div>🔐 আপনার bKash PIN দিয়ে কনফার্ম করুন</div>
            <div>✅ bKash থেকে কনফার্মেশন মেসেজ আসবে</div>
            <div>📝 <b>Transaction ID</b> উপরে বসিয়ে VERIFY করুন</div>`;
    } else if (method === 'nagad') {
        instrBox.style.background = '#F6921E';
        numEl.textContent = '01854707074';
        stepsEl.innerHTML = `
            <div>📱 Nagad App ওপেন করুন অথবা Dial <b>*167#</b></div>
            <div>👉 <span style="background:#FFD700;color:#000;padding:1px 6px;border-radius:4px;font-weight:700;">Send Money</span> তে ক্লিক করুন</div>
            <div>📞 নম্বর: <b id="payNumber">01854707074</b> <button onclick="copyNumber()" style="background:rgba(255,255,255,0.25);border:none;color:#fff;padding:3px 10px;border-radius:6px;font-size:0.7rem;font-weight:700;cursor:pointer;margin-left:6px;">Copy</button></div>
            <div>💰 Amount: <span style="color:#FFD700;font-weight:800;" id="payAmount">${document.getElementById('totalAmount').textContent}</span></div>
            <div>🔐 আপনার Nagad PIN দিয়ে কনফার্ম করুন</div>
            <div>✅ Nagad থেকে কনফার্মেশন মেসেজ আসবে</div>
            <div>📝 <b>Transaction ID</b> উপরে বসিয়ে VERIFY করুন</div>`;
    }
}

function copyNumber() {
    const num = document.getElementById('payNumber').textContent;
    navigator.clipboard.writeText(num).then(() => showToast('✅ Number copied!')).catch(() => {
        const t = document.createElement('textarea');
        t.value = num;
        document.body.appendChild(t);
        t.select();
        document.execCommand('copy');
        document.body.removeChild(t);
        showToast('✅ Number copied!');
    });
}

async function submitOrder() {
    const uid = document.getElementById('uidInput').value.trim();
    const phone = document.getElementById('phoneInput').value.trim();
    const trx = document.getElementById('trxInput').value.trim();
    
    if (!uid) { showToast('❌ Enter Player ID!'); return; }
    if (!phone) { showToast('❌ Enter phone number!'); return; }
    if (!trx) { showToast('❌ Enter Transaction ID!'); return; }
    
    let item = '', price = 0;
    if (currentType === 'diamond') {
        if (!selectedDiamond) { showToast('❌ Select diamonds!'); return; }
        item = selectedDiamond + ' Diamond';
        price = prices.diamonds[selectedDiamond].price;
    } else if (currentType === 'weekly_monthly') {
        if (!selectedWM) { showToast('❌ Select a package!'); return; }
        item = prices.passes[selectedWM].name;
        price = prices.passes[selectedWM].price;
    } else if (prices.passes[currentType]) {
        item = prices.passes[currentType].name;
        price = prices.passes[currentType].price;
    } else if (prices.specials[currentType]) {
        item = prices.specials[currentType].name;
        price = prices.specials[currentType].price;
    }
    
    // Send to Telegram
    const msg = `🛒 *SS TOP-UP New Order!*\n\n🎮 UID: \`${uid}\`\n📦 Item: ${item}\n💰 Price: ৳${price}\n💳 Payment: ${selectedPayment}\n📱 Number: ${phone}\n🧾 TrxID: ${trx}\n📅 Time: ${new Date().toLocaleString()}`;
    
    try {
        await fetch(TG_API, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ chat_id: TG_CHAT, text: msg, parse_mode: 'Markdown' })
        });
    } catch(e) { console.log('TG send failed', e); }
    
    // Save order to localStorage
    const orders = getOrders();
    orders.push({ uid, item, price, payment: selectedPayment, date: new Date().toLocaleString(), status: 'Pending' });
    localStorage.setItem('ss_orders', JSON.stringify(orders));
    
    showToast('✅ Order placed successfully!');
    
    setTimeout(() => {
        closeModal();
        document.getElementById('uidInput').value = '';
        document.getElementById('phoneInput').value = '';
        document.getElementById('trxInput').value = '';
        selectedDiamond = null;
    }, 1000);
}

function hideAllSections() {
    document.getElementById('homeContent').style.display = 'none';
    document.getElementById('ordersSection').classList.remove('show');
    document.getElementById('addMoneySection').classList.remove('show');
    document.getElementById('accountSection').classList.remove('show');
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
}

function showHome() {
    hideAllSections();
    document.getElementById('homeContent').style.display = 'block';
    document.getElementById('navHome').classList.add('active');
}

function showOrders() {
    hideAllSections();
    document.getElementById('ordersSection').classList.add('show');
    document.getElementById('navOrders').classList.add('active');
    renderOrders();
}

function showAddMoney() {
    hideAllSections();
    document.getElementById('addMoneySection').classList.add('show');
    document.getElementById('navAddMoney').classList.add('active');
}

function showAccount() {
    hideAllSections();
    document.getElementById('accountSection').classList.add('show');
    document.getElementById('navAccount').classList.add('active');
    const user = localStorage.getItem('ss_user');
    if (user) {
        const u = JSON.parse(user);
        document.getElementById('accountName').textContent = u.name;
        document.getElementById('accountEmail').textContent = u.email;
        document.getElementById('profileSetupCard').style.display = 'none';
        updateAccountStats();
    } else {
        document.getElementById('profileSetupCard').style.display = 'block';
    }
    // Always try to load photo
    const photo = localStorage.getItem('ss_profile_photo');
    if (photo) showProfilePhoto(photo);
}

let addPaymentMethod = 'bkash';
function selectAddPayment(el, method) {
    document.querySelectorAll('#addMoneySection .payment-option').forEach(p => p.classList.remove('selected'));
    el.classList.add('selected');
    addPaymentMethod = method;
}

async function submitAddMoney() {
    const amount = document.getElementById('addMoneyAmount').value.trim();
    const phone = document.getElementById('addMoneyPhone').value.trim();
    const trx = document.getElementById('addMoneyTrx').value.trim();
    
    if (!amount) { showToast('❌ Enter amount!'); return; }
    if (!phone) { showToast('❌ Enter phone number!'); return; }
    if (!trx) { showToast('❌ Enter Transaction ID!'); return; }
    
    const msg = `💰 *SS TOP-UP Add Money Request*\n\n💵 Amount: ৳${amount}\n💳 Payment: ${addPaymentMethod}\n📱 Number: ${phone}\n🧾 TrxID: ${trx}\n📅 Time: ${new Date().toLocaleString()}`;
    
    try {
        await fetch(TG_API, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ chat_id: TG_CHAT, text: msg, parse_mode: 'Markdown' })
        });
        showToast('✅ Request sent successfully!');
        document.getElementById('addMoneyAmount').value = '';
        document.getElementById('addMoneyPhone').value = '';
        document.getElementById('addMoneyTrx').value = '';
    } catch(e) {
        showToast('❌ Failed! Try again.');
    }
}

// Demo orders
const DEMO_ORDERS = [
    { name: 'Sakib Gaming', item: '1X Weekly', price: 250, status: 'Running', uid: '8374629105' },
    { name: 'Rifat Boss', item: '520 Diamond', price: 580, status: 'Completed', uid: '7291038456' },
    { name: 'Nayeem FF', item: 'Monthly', price: 950, status: 'Completed', uid: '6182934750' },
    { name: 'Tanvir Pro', item: 'Weekly Lite', price: 120, status: 'Completed', uid: '9081726354' },
    { name: 'Rahat King', item: 'Level Up Pass', price: 450, status: 'Completed', uid: '5039182746' },
    { name: 'Fahim Star', item: '100 Diamond', price: 120, status: 'Running', uid: '4028193756' },
    { name: 'Arif Hunter', item: 'EVO Access', price: 850, status: 'Completed', uid: '3019284756' },
    { name: 'Mizan BD', item: '2X Weekly', price: 480, status: 'Completed', uid: '2091837465' },
];

// Orders stored in localStorage
function getOrders() {
    try { return JSON.parse(localStorage.getItem('ss_orders') || '[]'); } catch(e) { return []; }
}

function renderOrderCard(o) {
    const colors = ['#06B6D4','#F59E0B','#8B5CF6','#EC4899','#EF4444','#22C55E','#6366F1','#14B8A6'];
    const nameOrUid = o.name || ('UID: ' + o.uid);
    const color = colors[Math.abs(hashCode(nameOrUid)) % colors.length];
    const initial = nameOrUid[0].toUpperCase();
    const statusColor = o.status === 'Running' ? 'background:#3B82F6;color:#fff;' : o.status === 'Completed' ? 'background:#22C55E;color:#fff;' : 'background:#FEF3C7;color:#92400E;';
    return `<div style="display:flex;align-items:center;gap:12px;padding:14px 16px;background:#fff;border-radius:14px;margin-bottom:8px;border:1px solid var(--border);box-shadow:var(--shadow);">
        <div style="width:44px;height:44px;border-radius:50%;background:${color};display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:1.1rem;flex-shrink:0;">${initial}</div>
        <div style="flex:1;min-width:0;">
            <div style="font-weight:700;font-size:0.88rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${nameOrUid}</div>
            <div style="font-size:0.76rem;color:var(--text-muted);margin-top:2px;">${o.item} - ৳${o.price}</div>
        </div>
        <span style="padding:4px 12px;border-radius:20px;font-size:0.7rem;font-weight:700;${statusColor}">${o.status || 'Pending'}</span>
    </div>`;
}

function renderHomeOrders() {
    const el = document.getElementById('homeOrdersList');
    el.innerHTML = DEMO_ORDERS.map(o => renderOrderCard(o)).join('');
}

function renderOrders() {
    const userOrders = getOrders();
    const el = document.getElementById('ordersList');
    if (userOrders.length === 0) {
        el.innerHTML = '<div style="text-align:center;padding:40px 20px;color:var(--text-muted);"><i class="fas fa-inbox" style="font-size:2.5rem;margin-bottom:12px;display:block;opacity:0.3;"></i><p>No orders yet</p></div>';
        return;
    }
    el.innerHTML = userOrders.slice(-10).reverse().map(o => renderOrderCard(o)).join('');
}

function hashCode(s) { let h=0; for(let i=0;i<s.length;i++) h=((h<<5)-h)+s.charCodeAt(i)|0; return h; }

function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.style.display = 'block';
    setTimeout(() => t.style.display = 'none', 3000);
}

// Login System
function handleLogin() {
    const name = document.getElementById('loginName').value.trim();
    const email = document.getElementById('loginEmail').value.trim();
    const phone = document.getElementById('loginPhone').value.trim();
    
    if (!name || !email || !email.includes('@')) {
        showToast('❌ Please enter name and valid email!');
        return;
    }
    
    const user = { name, email, phone, loginDate: new Date().toLocaleString() };
    localStorage.setItem('ss_user', JSON.stringify(user));
    
    // Update UI
    document.querySelector('.profile-btn').textContent = name[0].toUpperCase();
    document.getElementById('accountName').textContent = name;
    document.getElementById('accountEmail').textContent = email;
    document.getElementById('profileSetupCard').style.display = 'none';
    // Generate support pin
    if (!localStorage.getItem('ss_support_pin')) {
        localStorage.setItem('ss_support_pin', Math.floor(1000000 + Math.random() * 9000000).toString());
    }
    updateAccountStats();
    
    showToast('✅ Profile saved!');
    
    // Notify admin via Telegram
    fetch(TG_API, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
            chat_id: TG_CHAT, 
            text: `👤 *New User Registered!*\n\n📛 Name: ${name}\n📧 Email: ${email}\n📱 Phone: ${phone || 'N/A'}\n📅 Time: ${user.loginDate}`,
            parse_mode: 'Markdown'
        })
    }).catch(e => {});
}

function handleProfilePhoto(input) {
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            const dataUrl = e.target.result;
            localStorage.setItem('ss_profile_photo', dataUrl);
            showProfilePhoto(dataUrl);
            showToast('✅ Profile photo updated!');
        };
        reader.readAsDataURL(input.files[0]);
    }
}

function showProfilePhoto(dataUrl) {
    const img = document.getElementById('accountAvatarImg');
    const icon = document.getElementById('accountAvatarIcon');
    if (dataUrl) {
        img.src = dataUrl;
        img.style.display = 'block';
        icon.style.display = 'none';
    }
}

function updateAccountStats() {
    const pin = localStorage.getItem('ss_support_pin');
    if (pin) document.getElementById('statSupportPin').textContent = pin;
    // Load photo
    const photo = localStorage.getItem('ss_profile_photo');
    if (photo) showProfilePhoto(photo);
}

function checkLogin() {
    const user = localStorage.getItem('ss_user');
    if (user) {
        const u = JSON.parse(user);
        document.querySelector('.profile-btn').textContent = u.name[0].toUpperCase();
        if (!localStorage.getItem('ss_support_pin')) {
            localStorage.setItem('ss_support_pin', Math.floor(1000000 + Math.random() * 9000000).toString());
        }
        updateAccountStats();
    }
}

function logoutUser() {
    localStorage.removeItem('ss_user');
    showToast('Logged out!');
    showAccount();
}

// Init
checkLogin();
loadPrices();
renderHomeOrders();
</script>
</body>
</html>
