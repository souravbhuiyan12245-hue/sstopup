<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>SS TOP-UP | Free Fire Diamond Store</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        :root {
            --primary: #6C3CE1;
            --primary-dark: #5228CC;
            --primary-light: #8B5CF6;
            --accent: #F97316;
            --accent-dark: #EA580C;
            --bg: #F5F3FF;
            --white: #FFFFFF;
            --card-bg: #FFFFFF;
            --text: #1E1B4B;
            --text-muted: #6B7280;
            --success: #22C55E;
            --gold: #F59E0B;
            --pink: #EC4899;
            --danger: #EF4444;
            --border: rgba(108,60,225,0.1);
            --shadow: 0 2px 12px rgba(108,60,225,0.12);
            --shadow-lg: 0 8px 30px rgba(108,60,225,0.18);
        }
        
        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            padding-bottom: 80px;
            -webkit-tap-highlight-color: transparent;
        }

        /* Header */
        .header {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            padding: 16px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 4px 20px rgba(108,60,225,0.3);
        }
        .header-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .logo-icon {
            width: 42px;
            height: 42px;
            background: rgba(255,255,255,0.2);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            backdrop-filter: blur(10px);
        }
        .logo-text {
            color: #fff;
            font-size: 1.2rem;
            font-weight: 800;
            letter-spacing: -0.5px;
        }
        .logo-text small {
            display: block;
            font-size: 0.65rem;
            font-weight: 400;
            opacity: 0.8;
            letter-spacing: 1px;
        }
        .header-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .header-btn {
            width: 38px;
            height: 38px;
            background: rgba(255,255,255,0.15);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1rem;
            cursor: pointer;
            border: none;
            backdrop-filter: blur(10px);
            transition: all 0.2s;
        }
        .header-btn:active { transform: scale(0.92); }
        .profile-btn {
            width: 38px;
            height: 38px;
            background: var(--accent);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 0.9rem;
            font-weight: 800;
            cursor: pointer;
        }

        /* Announcement */
        .announce-bar {
            background: linear-gradient(135deg, #FEF3C7, #FDE68A);
            padding: 10px 20px;
            font-size: 0.82rem;
            color: #92400E;
            display: none;
            align-items: center;
            gap: 8px;
            font-weight: 500;
        }
        .announce-bar.show { display: flex; }
        .announce-bar i { font-size: 1rem; }

        /* Content */
        .content { padding: 16px; }

        /* Section Title */
        .section-title {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text);
        }
        .section-title .badge {
            background: var(--accent);
            color: #fff;
            font-size: 0.6rem;
            padding: 2px 8px;
            border-radius: 20px;
            font-weight: 700;
            text-transform: uppercase;
        }

        /* Special Offers Grid */
        .offers-scroll {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-bottom: 20px;
        }
        .offer-card {
            background: linear-gradient(145deg, #1a1a2e, #16213e);
            border-radius: 16px;
            padding: 0;
            text-align: center;
            color: #fff;
            cursor: pointer;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.08);
            min-height: 140px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-end;
        }
        .offer-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: radial-gradient(ellipse at top center, rgba(139,92,246,0.25) 0%, transparent 70%);
            pointer-events: none;
        }
        .offer-card::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 50%;
            background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
            pointer-events: none;
        }
        .offer-card:active { transform: scale(0.96); }
        .offer-card { animation: fadeInUp 0.5s ease both; }
        .offer-card:nth-child(1) { animation-delay: 0.1s; }
        .offer-card:nth-child(2) { animation-delay: 0.2s; }
        .offer-card:nth-child(3) { animation-delay: 0.3s; }
        .offer-card:nth-child(4) { animation-delay: 0.4s; }
        .offer-card .icon { font-size: 2.8rem; margin-bottom: 6px; display: flex; align-items: center; justify-content: center; filter: drop-shadow(0 4px 12px rgba(255,100,50,0.4)); position: relative; z-index: 2; height: 80px; }
        .offer-card .icon svg, .offer-card .icon img { width: 80px; height: 80px; }
        .product-card .card-icon svg { width: 60px; height: 60px; position: relative; z-index: 2; }
        .offer-card .title { font-size: 0.88rem; font-weight: 800; text-shadow: 0 2px 8px rgba(0,0,0,0.6); position: relative; z-index: 2; padding: 0 8px; }
        .offer-card .sub { font-size: 0.75rem; opacity: 0.9; margin-top: 2px; margin-bottom: 12px; font-weight: 600; position: relative; z-index: 2; text-shadow: 0 1px 4px rgba(0,0,0,0.5); }
        .offer-card.card-red::before { background: radial-gradient(ellipse at top center, rgba(239,68,68,0.3) 0%, transparent 70%); }
        .offer-card.card-gold::before { background: radial-gradient(ellipse at top center, rgba(245,158,11,0.3) 0%, transparent 70%); }
        .offer-card.card-pink::before { background: radial-gradient(ellipse at top center, rgba(236,72,153,0.3) 0%, transparent 70%); }
        .offer-card.card-cyan::before { background: radial-gradient(ellipse at top center, rgba(14,165,233,0.3) 0%, transparent 70%); }

        /* Game Section */
        .game-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 14px;
        }
        .game-logo {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, #FF6B35, #FF4444);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
            font-weight: 900;
            color: #fff;
        }
        .game-name {
            font-size: 1.1rem;
            font-weight: 800;
        }

        /* Product Grid */
        .product-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-bottom: 24px;
        }
        .product-card {
            background: linear-gradient(145deg, #1a1a2e, #16213e);
            border-radius: 16px;
            padding: 0;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            border: 1px solid rgba(255,255,255,0.08);
            box-shadow: 0 4px 16px rgba(0,0,0,0.3);
            position: relative;
            overflow: hidden;
            animation: fadeInUp 0.5s ease both;
        }
        .product-card:active { transform: scale(0.95); box-shadow: 0 8px 30px rgba(0,0,0,0.4); }
        .product-card:nth-child(1) { animation-delay: 0.1s; }
        .product-card:nth-child(2) { animation-delay: 0.2s; }
        .product-card:nth-child(3) { animation-delay: 0.3s; }
        .product-card:nth-child(4) { animation-delay: 0.4s; }
        .product-card:nth-child(5) { animation-delay: 0.5s; }
        .product-card .card-icon {
            width: 100%;
            height: 90px;
            background: linear-gradient(145deg, #0f0f23, #1a1a3e);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            color: #fff;
            position: relative;
            overflow: hidden;
        }
        .product-card .card-icon::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: radial-gradient(ellipse at center, rgba(139,92,246,0.2) 0%, transparent 70%);
        }
        .product-card .card-icon::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 40%;
            background: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
        }
        .product-card .card-text {
            padding: 10px 8px 14px;
            background: linear-gradient(to bottom, #1a1a2e, #12122a);
        }
        .product-card .card-title {
            font-size: 0.74rem;
            font-weight: 700;
            color: #fff;
            line-height: 1.3;
        }
        .product-card .card-sub {
            font-size: 0.62rem;
            color: rgba(255,255,255,0.5);
            margin-top: 3px;
        }
        .product-card .tag {
            position: absolute;
            top: 8px;
            right: 8px;
            background: var(--danger);
            color: #fff;
            font-size: 0.5rem;
            padding: 3px 8px;
            border-radius: 8px;
            font-weight: 700;
            z-index: 2;
            animation: tagPulse 1.5s ease infinite;
        }
        .product-card .tag.hot { background: #EF4444; }
        .product-card .tag.new { background: var(--success); }
        @keyframes tagPulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.85; transform: scale(1.1); }
        }

        /* Order Form Modal */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 200;
            align-items: flex-end;
            justify-content: center;
            backdrop-filter: blur(4px);
        }
        .modal-overlay.show { display: flex; }
        .modal {
            background: var(--white);
            border-radius: 24px 24px 0 0;
            width: 100%;
            max-width: 500px;
            max-height: 92vh;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
            padding: 24px 20px 40px;
            animation: slideUp 0.3s ease;
        }
        @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
        .modal-handle {
            width: 40px;
            height: 4px;
            background: #D1D5DB;
            border-radius: 4px;
            margin: 0 auto 20px;
        }
        .modal h3 {
            font-size: 1.1rem;
            font-weight: 800;
            margin-bottom: 4px;
        }
        .modal .modal-sub {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-bottom: 20px;
        }
        .form-group { margin-bottom: 16px; }
        .form-label {
            font-size: 0.82rem;
            font-weight: 600;
            margin-bottom: 6px;
            display: block;
            color: var(--text);
        }
        .form-input {
            width: 100%;
            padding: 12px 14px;
            border: 2px solid #E5E7EB;
            border-radius: 12px;
            font-size: 0.9rem;
            font-family: inherit;
            outline: none;
            transition: border 0.2s;
            background: #F9FAFB;
        }
        .form-input:focus { border-color: var(--primary); background: #fff; }
        .form-input::placeholder { color: #9CA3AF; }

        /* Diamond Select */
        .diamond-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin-bottom: 8px;
        }
        .diamond-option {
            padding: 10px 6px;
            background: #F3F4F6;
            border: 2px solid transparent;
            border-radius: 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.78rem;
            font-weight: 600;
        }
        .diamond-option:active { transform: scale(0.95); }
        .diamond-option.selected {
            border-color: var(--primary);
            background: #EDE9FE;
            color: var(--primary);
        }
        .diamond-option .dm-icon { font-size: 1.2rem; display: block; margin-bottom: 4px; }
        .diamond-option .dm-price {
            font-size: 0.68rem;
            color: var(--text-muted);
            margin-top: 2px;
        }
        .diamond-option.selected .dm-price { color: var(--primary); }
        .diamond-option .dm-original {
            font-size: 0.58rem;
            color: #9CA3AF;
            text-decoration: line-through;
        }

        /* Payment Select */
        .payment-options { display: flex; flex-direction: column; gap: 8px; }
        .payment-option {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            background: #F3F4F6;
            border: 2px solid transparent;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .payment-option.selected { border-color: var(--primary); background: #EDE9FE; }
        .payment-option .pay-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            font-weight: 800;
        }
        .payment-option .pay-name { font-size: 0.85rem; font-weight: 600; }
        .payment-option .pay-num { font-size: 0.72rem; color: var(--text-muted); }
        .bkash-icon { background: #E2136E; color: #fff; }
        .nagad-icon { background: #F6921E; color: #fff; }
        .rocket-icon { background: #8C3494; color: #fff; }

        /* Submit Button */
        .submit-btn {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: #fff;
            border: none;
            border-radius: 14px;
            font-size: 1rem;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            margin-top: 20px;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(108,60,225,0.3);
        }
        .submit-btn:active { transform: scale(0.97); }
        .submit-btn:disabled { opacity: 0.5; }

        /* Total Bar */
        .total-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 16px;
            background: #EDE9FE;
            border-radius: 12px;
            margin-top: 16px;
        }
        .total-bar .label { font-size: 0.85rem; font-weight: 600; }
        .total-bar .amount { font-size: 1.2rem; font-weight: 800; color: var(--primary); }

        /* Bottom Navigation */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--white);
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-around;
            padding: 8px 0 12px;
            z-index: 100;
            box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
        }
        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 3px;
            font-size: 0.65rem;
            color: var(--text-muted);
            cursor: pointer;
            padding: 4px 12px;
            border: none;
            background: none;
            font-family: inherit;
            transition: color 0.2s;
        }
        .nav-item.active { color: var(--primary); }
        .nav-item i { font-size: 1.2rem; }

        /* Help FAB */
        .help-fab {
            position: fixed;
            bottom: 80px;
            right: 16px;
            background: var(--accent);
            color: #fff;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            box-shadow: 0 4px 15px rgba(249,115,22,0.4);
            cursor: pointer;
            border: none;
            z-index: 90;
            transition: all 0.3s;
        }
        .help-fab:active { transform: scale(0.9); }

        /* Toast */
        .toast {
            position: fixed;
            top: 80px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--success);
            color: #fff;
            padding: 12px 24px;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: 600;
            z-index: 300;
            display: none;
            animation: fadeIn 0.3s ease;
            box-shadow: 0 4px 15px rgba(34,197,94,0.3);
        }
        @keyframes fadeIn { from { opacity:0; transform:translateX(-50%) translateY(-10px); } to { opacity:1; transform:translateX(-50%) translateY(0); } }
        
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.08); }
        }
        @keyframes shake {
            0%, 100% { transform: rotate(0deg); }
            25% { transform: rotate(-5deg); }
            75% { transform: rotate(5deg); }
        }
        @keyframes glow {
            0%, 100% { box-shadow: 0 0 5px rgba(108,60,225,0.2); }
            50% { box-shadow: 0 0 20px rgba(108,60,225,0.4); }
        }
        
        .section-title { animation: fadeInUp 0.4s ease both; }
        .game-header { animation: fadeInUp 0.4s ease both; animation-delay: 0.1s; }

        /* Status page */
        .status-section { display: none; padding: 20px; }
        .status-section.show { display: block; }
        .status-card {
            background: var(--white);
            border-radius: 16px;
            padding: 20px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow);
            margin-bottom: 12px;
        }
        .status-card h4 { font-size: 0.9rem; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
        .status-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #F3F4F6; font-size: 0.82rem; }
        .status-row:last-child { border-bottom: none; }
        .status-badge { padding: 3px 10px; border-radius: 20px; font-size: 0.7rem; font-weight: 700; }
        .badge-pending { background: #FEF3C7; color: #92400E; }
        .badge-done { background: #D1FAE5; color: #065F46; }
        /* Login Screen */
        .login-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            z-index: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .login-overlay.hidden { display: none; }
        .login-card {
            background: var(--white);
            border-radius: 24px;
            padding: 40px 28px;
            max-width: 380px;
            width: 100%;
            text-align: center;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }
        .login-card .logo-big { font-size: 3rem; margin-bottom: 12px; display: block; }
        .login-card h2 { font-size: 1.3rem; font-weight: 800; color: var(--text); margin-bottom: 4px; }
        .login-card .login-sub { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 24px; }
        .login-card .form-input { margin-bottom: 12px; }
        .login-card .login-btn {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: #fff;
            border: none;
            border-radius: 14px;
            font-size: 1rem;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            margin-top: 8px;
            box-shadow: 0 4px 15px rgba(108,60,225,0.3);
            transition: all 0.3s;
        }
        .login-card .login-btn:active { transform: scale(0.97); }
        .login-card .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 20px 0;
            color: var(--text-muted);
            font-size: 0.75rem;
        }
        .login-card .divider::before, .login-card .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #E5E7EB;
        }
        .google-btn {
            width: 100%;
            padding: 12px;
            background: #fff;
            border: 2px solid #E5E7EB;
            border-radius: 14px;
            font-size: 0.9rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            color: var(--text);
            transition: all 0.2s;
        }
        .google-btn:active { background: #F3F4F6; }
        .google-btn img { width: 20px; height: 20px; }
        .login-error { color: var(--danger); font-size: 0.78rem; margin-bottom: 8px; display: none; }
    </style>
</head>
<body>

<!-- Header -->
<div class="header">
    <div class="header-left">
        <div class="logo-icon">💎</div>
        <div class="logo-text">
            SS TOP-UP
            <small>DIAMOND STORE</small>
        </div>
    </div>
    <div class="header-right">
        <button class="header-btn" onclick="showHome()"><i class="fas fa-home"></i></button>
        <button class="header-btn" onclick="showOrders()"><i class="fas fa-receipt"></i></button>
        <div class="profile-btn">S</div>
    </div>
</div>

<!-- Announcement -->
<div class="announce-bar" id="announceBar">
    <i class="fas fa-bullhorn"></i>
    <span id="announceText"></span>
</div>

<!-- Home Content -->
<div class="content" id="homeContent">

    <!-- Special Offers -->
    <div class="section-title">🔥 SPECIAL OFFER <span class="badge">HOT</span></div>
    <div class="offers-scroll">
        <div class="offer-card" onclick="openModal('weekly_lite')">
