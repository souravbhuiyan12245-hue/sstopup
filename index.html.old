<!-- Orders Section -->
<div class="status-section" id="ordersSection">
    <div class="section-title">📋 Latest Orders</div>
    <p style="color:var(--text-muted);font-size:0.8rem;margin-bottom:14px;">Your recent <span style="color:var(--danger);font-weight:700;">10 orders</span> at a glance</p>
    <div id="ordersList"></div>
</div>

<!-- Add Money Section -->
<div class="status-section" id="addMoneySection">
    <div class="section-title">💰 Add Money</div>
    <div class="status-card">
        <div style="text-align:center;margin-bottom:16px;">
            <div style="font-size:2.5rem;margin-bottom:8px;">💳</div>
            <div style="font-size:0.85rem;color:var(--text-muted);">Current Balance</div>
            <div style="font-size:2rem;font-weight:800;color:var(--primary);" id="balanceDisplay">৳0</div>
        </div>
        <div class="form-group">
            <label class="form-label">Enter Amount</label>
            <input class="form-input" type="number" id="addMoneyAmount" placeholder="Amount (৳)" inputmode="numeric">
        </div>
        <div class="form-group">
            <label class="form-label">💳 Payment Method</label>
            <div class="payment-options">
                <div class="payment-option selected" onclick="selectAddPayment(this,'bkash')">
                    <div class="pay-icon bkash-icon">b</div>
                    <div>
                        <div class="pay-name">bKash</div>
                        <div class="pay-num">01606335174</div>
                    </div>
                </div>
                <div class="payment-option" onclick="selectAddPayment(this,'nagad')">
                    <div class="pay-icon nagad-icon">N</div>
                    <div>
                        <div class="pay-name">Nagad</div>
                        <div class="pay-num">01854707074</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">📱 Your Number</label>
            <input class="form-input" type="tel" id="addMoneyPhone" placeholder="01XXXXXXXXX" inputmode="numeric">
        </div>
        <div class="form-group">
            <label class="form-label">🧾 Transaction ID</label>
            <input class="form-input" type="text" id="addMoneyTrx" placeholder="Enter Transaction ID">
        </div>
        <button class="submit-btn" onclick="submitAddMoney()">
            <i class="fas fa-plus-circle"></i> Add Money
        </button>
    </div>
    <div class="status-card" style="margin-top:14px;">
        <h4 style="font-size:0.85rem;margin-bottom:10px;">📖 How to Add Money</h4>
        <div style="font-size:0.8rem;color:var(--text-muted);line-height:1.8;">
            1️⃣ Enter the amount you want to add<br>
            2️⃣ Select bKash or Nagad<br>
            3️⃣ Send money to the number shown<br>
            4️⃣ Enter your phone number & Transaction ID<br>
            5️⃣ Click "Add Money" button<br>
            6️⃣ Balance will be added within 5-10 minutes ✅
        </div>
    </div>
</div>

<!-- Order Modal -->
<div class="modal-overlay" id="modalOverlay" onclick="if(event.target===this)closeModal()">
    <div class="modal">
        <div class="modal-handle"></div>
        <h3 id="modalTitle">💎 Diamond TopUp</h3>
        <p class="modal-sub" id="modalSub">Enter your Free Fire UID and select a package</p>

        <!-- UID Input -->
        <div class="form-group">
            <label class="form-label">🎮 Player ID (UID)</label>
            <input class="form-input" type="text" id="uidInput" placeholder="Enter your Free Fire UID" inputmode="numeric">
        </div>

        <!-- Diamond Select (for diamond type) -->
        <div class="form-group" id="diamondSelectGroup">
            <label class="form-label">💎 Select Diamonds</label>
            <div class="diamond-grid" id="diamondGrid"></div>
        </div>

        <!-- Weekly/Monthly Select -->
        <div class="form-group" id="wmSelectGroup" style="display:none;">
            <label class="form-label">📅 Select Package</label>
            <div class="diamond-grid" id="wmGrid"></div>
        </div>

        <!-- Pass Info (for pass type) -->
        <div class="form-group" id="passInfoGroup" style="display:none;">
            <div class="total-bar">
                <span class="label" id="passName">Weekly Lite</span>
                <span class="amount" id="passPrice">৳120</span>
            </div>
        </div>

        <!-- Payment -->
        <div class="form-group">
            <label class="form-label">💳 Payment Method</label>
            <div class="payment-options">
                <div class="payment-option selected" onclick="selectPayment(this,'bkash')">
                    <div class="pay-icon bkash-icon">b</div>
                    <div>
                        <div class="pay-name">bKash</div>
                        <div class="pay-num">Send Money</div>
                    </div>
                </div>
                <div class="payment-option" onclick="selectPayment(this,'nagad')">
                    <div class="pay-icon nagad-icon">N</div>
                    <div>
                        <div class="pay-name">Nagad</div>
                        <div class="pay-num">Send Money</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total -->
        <div class="total-bar" id="totalBar">
            <span class="label">Total Price</span>
            <span class="amount" id="totalAmount">৳0</span>
        </div>

        <!-- bKash Style Payment Instructions -->
        <div id="paymentInstructions" style="background:#E2136E;border-radius:14px;padding:18px 16px;margin-top:14px;color:#fff;">
            <div style="font-weight:700;font-size:0.9rem;margin-bottom:12px;">🧾 Transaction ID দিন</div>
            <input class="form-input" type="text" id="trxInput" placeholder="Transaction ID দিন" style="background:rgba(255,255,255,0.95);color:#333;border:none;margin-bottom:14px;">
            
            <div style="font-size:0.78rem;line-height:2;" id="paySteps">
                <div>📱 Dial <b>*247#</b> অথবা bKash App ওপেন করুন</div>
                <div>👉 <span style="background:#FFD700;color:#000;padding:1px 6px;border-radius:4px;font-weight:700;">Send Money</span> তে ক্লিক করুন</div>
                <div>📞 নম্বর: <b id="payNumber">01606335174</b> <button onclick="copyNumber()" style="background:rgba(255,255,255,0.25);border:none;color:#fff;padding:3px 10px;border-radius:6px;font-size:0.7rem;font-weight:700;cursor:pointer;margin-left:6px;">Copy</button></div>
                <div>💰 Amount: <span style="color:#FFD700;font-weight:800;" id="payAmount">৳0</span></div>
                <div>🔐 আপনার bKash PIN দিয়ে কনফার্ম করুন</div>
                <div>✅ bKash থেকে কনফার্মেশন মেসেজ আসবে</div>
                <div>📝 <b>Transaction ID</b> উপরে বসিয়ে VERIFY করুন</div>
            </div>
        </div>

        <!-- Phone Number -->
        <div class="form-group" style="margin-top:14px;">
            <label class="form-label">📱 Your Number</label>
            <input class="form-input" type="tel" id="phoneInput" placeholder="01XXXXXXXXX" inputmode="numeric">
        </div>

        <button class="submit-btn" onclick="submitOrder()" style="background:linear-gradient(135deg,#E2136E,#C4105A);">
            <i class="fas fa-check-circle"></i> VERIFY & Confirm Order
        </button>
    </div>
</div>

<!-- Account Section -->
<div class="status-section" id="accountSection">
    <!-- Profile Header with Photo Upload -->
    <div style="text-align:center;padding:24px 0 16px;">
        <div style="position:relative;width:90px;height:90px;margin:0 auto 14px;">
            <div style="width:90px;height:90px;border-radius:50%;border:3px solid var(--primary);overflow:hidden;background:linear-gradient(135deg,var(--primary),var(--primary-dark));display:flex;align-items:center;justify-content:center;" id="accountAvatarWrap">
                <img id="accountAvatarImg" src="" style="width:100%;height:100%;object-fit:cover;display:none;">
                <span id="accountAvatarIcon" style="font-size:2.2rem;color:#fff;">👤</span>
            </div>
            <label for="profilePhotoInput" style="position:absolute;bottom:0;right:0;width:30px;height:30px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;border:2px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,0.2);">
                <i class="fas fa-camera" style="color:#fff;font-size:0.7rem;"></i>
            </label>
            <input type="file" id="profilePhotoInput" accept="image/*" style="display:none;" onchange="handleProfilePhoto(this)">
        </div>
        <div style="font-size:1.15rem;font-weight:800;" id="accountName">Guest</div>
        <div style="font-size:0.8rem;color:var(--text-muted);" id="accountEmail">No email added</div>
        <div style="display:flex;align-items:center;justify-content:center;gap:6px;margin-top:6px;">
            <span style="font-size:0.82rem;color:var(--text-muted);">Available Balance :</span>
            <span style="font-size:0.95rem;font-weight:800;color:var(--primary);" id="accountBalance">0 Tk</span>
            <i class="fas fa-sync-alt" style="font-size:0.7rem;color:var(--primary);cursor:pointer;" onclick="showAddMoney()"></i>
        </div>
    </div>

    <!-- Stats Grid -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;">
        <div class="status-card" style="text-align:center;margin:0;padding:14px 10px;">
            <div style="font-size:1.3rem;font-weight:800;color:#3b82f6;" id="statSupportPin">—</div>
            <div style="font-size:0.7rem;color:var(--text-muted);margin-top:2px;">Support Pin</div>
        </div>
        <div class="status-card" style="text-align:center;margin:0;padding:14px 10px;">
            <div style="font-size:1.3rem;font-weight:800;color:#3b82f6;" id="statWeeklySpent">0 ৳</div>
            <div style="font-size:0.7rem;color:var(--text-muted);margin-top:2px;">Weekly Spent</div>
        </div>
        <div class="status-card" style="text-align:center;margin:0;padding:14px 10px;">
            <div style="font-size:1.3rem;font-weight:800;color:#f97316;" id="statTotalSpent">0</div>
            <div style="font-size:0.7rem;color:var(--text-muted);margin-top:2px;">Total Spent</div>
        </div>
        <div class="status-card" style="text-align:center;margin:0;padding:14px 10px;">
            <div style="font-size:1.3rem;font-weight:800;color:#f97316;" id="statTotalOrders">0</div>
            <div style="font-size:0.7rem;color:var(--text-muted);margin-top:2px;">Total Order</div>
        </div>
    </div>

    <!-- Account Info Card -->
    <div class="status-card" style="margin-bottom:12px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
            <i class="fas fa-shield-alt" style="color:var(--primary);font-size:1rem;"></i>
            <span style="font-weight:700;font-size:0.9rem;">Account Information</span>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid #F3F4F6;">
